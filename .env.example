# Optional: hit the live Royco Dawn API during sync instead of the recorded local Dawn fixture.
ROYCO_DAWN_LIVE=0

# Optional: load a recorded Dawn response or normalized RoycoMarketFixture[] from disk.
ROYCO_DAWN_FIXTURE_PATH=

# Optional: hit the live Pharos API during sync instead of fixture data.
PHAROS_API_KEY=ph_live_replace_me

# Optional: override the Pharos API host.
PHAROS_API_BASE=https://api.pharos.watch

# Optional: override the local SQLite file.
ROYCOPHAROS_DB_PATH=data/roycopharos.db
